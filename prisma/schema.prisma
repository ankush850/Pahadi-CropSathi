generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model PlantAnalysis {
  id                     String   @id @default(uuid())
  plantName              String
  diseaseName            String
  confidence             Float
  severity               Float
  treatments             String    // Stored as JSON string
  isHealthy              Boolean
  pestsDetected          Boolean
  pestDetails            String?
  detectedPests          String?  // Stored as JSON string
  nutrientDeficiency     Boolean
  deficiencyDetails      String?
  weedDetected           Boolean
  yieldPrediction        String?
  soilTypeRecommendation String
  soilExplanation        String
  recommendedCrops       String   // Stored as JSON string
  createdAt              DateTime @default(now())
}

model RegionAnalysis {
  id                 String   @id @default(uuid())
  soilPotential      String
  climateSuitability String
  waterSources       String
  overallRating      String
  areaSize           String?
  coordinates        String?
  createdAt          DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      String   // 'user' or 'model'
  text      String
  createdAt DateTime @default(now())
}
